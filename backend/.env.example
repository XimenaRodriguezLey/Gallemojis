# ───── Servidor ─────
PORT=3001

# ───── Base de datos ─────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gallemojis

# ───── Seguridad ─────
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRES_IN=12h

# Clave compartida con los módulos PN532 (Header X-Module-Key)
MODULE_API_KEY=clave-del-modulo-nfc

# ───── CORS ─────
# Coma-separado. Usar * para abrir todo en desarrollo.
CORS_ORIGIN=*
